//// [tests/cases/compiler/utf16TemplateLiteralInference.ts] ////

=== utf16TemplateLiteralInference.ts ===
type Head<S> = S extends `${infer C}${string}` ? C : never;
>Head : Head<S>

type Rest<S> = S extends `${string}${infer R}` ? R : never;
>Rest : Rest<S>

type A = [Head<"😀abc">, Rest<"😀abc">];
>A : A

declare let a: A;
>a : A

const chk: ["😀", "abc"] = a;
>chk : ["😀", "abc"]
>a : A

