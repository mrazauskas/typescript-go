=== utf16TemplateLiteralInference.ts ===
type Heads<S> = S extends `${infer C}${infer R}` ? [C, R] : never;
>Heads : Heads<S>

type A = Heads<"😀abc">;
>A : ["\uD83D", "\uDE00abc"]

declare let a: A;
>a : ["\uD83D", "\uDE00abc"]

const chk: ["😀", "abc"] = a;
>chk : ["😀", "abc"]
>a : ["\uD83D", "\uDE00abc"]

